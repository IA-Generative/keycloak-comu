{
  "name": "keycloak-comu-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "type-check": "vue-tsc --noEmit",
    "generate:client": "sh -c 'openapi-ts -i \"${HEY_API_INPUT:-http://localhost:8080/api/openapi.json}\" -o src/client -c @hey-api/client-fetch'"
  },
  "dependencies": {
    "@gouvfr/dsfr": "^1.12.1",
    "@gouvminint/vue-dsfr": "^8.4.0",
    "oidc-client-ts": "^3.1.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.80.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.12.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.1",
    "vue-tsc": "^2.2.0"
  }
}