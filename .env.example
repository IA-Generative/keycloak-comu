# Server
ENV=development
PORT=8080
PUBLIC_URL=http://localhost:8080

# Database (shared with Keycloak)
DATABASE_URL=postgres://keycloak:password@localhost:5432/keycloak?sslmode=disable

# OIDC
OIDC_ISSUER_URL=http://localhost:8081/realms/mirai
OIDC_INTERNAL_ISSUER_URL=http://keycloak:8080/realms/mirai
OIDC_JWKS_URL=http://keycloak:8080/realms/mirai/protocol/openid-connect/certs
OIDC_CLIENT_ID=keycloak-comu
OIDC_SWAGGER_CLIENT_ID=keycloak-comu-swagger

# Keycloak Admin API
KEYCLOAK_URL=http://keycloak:8080/
KEYCLOAK_REALM=mirai
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# SMTP (Mailhog for local dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@keycloak-comu.local
SMTP_USER=
SMTP_PASSWORD=
SMTP_ENCRYPTION=none

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080

# Frontend
FRONTEND_ENABLED=false
